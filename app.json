{
  "expo": {
    "name": "Apartman Asistanı",
    "slug": "apartman-yonetici-asistani",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apartman.asistani"
    },
    "android": {
      "package": "com.apartman.asistani",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#111827",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#111827"
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "API_URL": "https://apartman-yonetici-asistani-production.up.railway.app/api",
      "eas": {
        "projectId": "98b55555-911c-4b79-b16a-3af21fd5eeea"
      }
    },
    "owner": "eral08"
  }
}
